[package]
name = "ExternCall"
version = "0.1.0"
description = "First sample using [<FidelityExtern>] bindings (ExternCall pathway)"
authors = ["SpeakEZ Technologies, Inc."]
license = "MIT"

[compilation]
target = "cpu"

[dependencies]
platform = { path = "/home/hhh/repos/Fidelity.Platform/CPU/Linux/x86_64/Fidelity.Platform.fidproj" }

[build]
sources = ["bindings/CMemory.clef", "ExternCall.clef"]
output = "externcall"
output_kind = "console"

[link]
libraries = ["c"]
