[package]
name = "BAREWireCollections"
version = "0.1.0"
description = "PRD-13a: BAREWire collection patterns validation"
authors = ["SpeakEZ Technologies, Inc."]
license = "MIT"

[compilation]
target = "cpu"

[dependencies]
# Types and operations are CCS intrinsics - no external library needed
platform = { path = "/home/hhh/repos/Fidelity.Platform/CPU/Linux/x86_64/Fidelity.Platform.fidproj" }

[build]
sources = ["BAREWireCollections.fs"]
output = "barewire_collections"
